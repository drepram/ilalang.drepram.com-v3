{
  "name": "ilalang-v3",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "prebuild": "npm run -s generate:importmap",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "payload": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts payload",
    "generate:types": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts payload generate:types",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation PAYLOAD_CONFIG_PATH=src/payload.config.ts payload generate:importmap",
    "generate:schema": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts payload generate:db-schema",
    "migrate": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts payload migrate",
    "migrate:create": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts payload migrate:create",
    "migrate:status": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts payload migrate:status",
    "import:ilalang": "tsx seed/import-ilalang.ts"
  },
  "dependencies": {
    "@payloadcms/db-vercel-postgres": "3.17.1",
    "@payloadcms/next": "3.17.1",
    "@payloadcms/richtext-lexical": "3.17.1",
    "@payloadcms/ui": "3.17.1",
    "cross-env": "^7.0.3",
    "csv-parse": "^5.5.6",
    "dotenv": "^16.4.5",
    "next": "15.5.16",
    "payload": "3.17.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "schema-dts": "^1.1.2",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/node": "^20.17.12",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3"
  }
}
